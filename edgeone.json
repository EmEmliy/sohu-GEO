{
  "version": 2,
  "build": {
    "command": "npm run build",
    "outputDirectory": "dist",
    "installCommand": "npm install"
  },
  "routes": [
    {
      "route": "/assets/*"
    },
    {
      "route": "/api/*"
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "status": 200
    }
  ]
}
